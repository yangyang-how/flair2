---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Flair2 — AI Campaign Studio">
  <div class="flex flex-col items-center justify-center gap-8 py-20 text-center">
    <h1 class="text-5xl font-bold tracking-tight">
      AI Campaign
      <span class="text-[var(--color-accent)]">Studio</span>
    </h1>

    <p class="max-w-lg text-lg text-[var(--color-text-muted)]">
      Multi-stage AI pipeline that generates social media marketing campaigns.
      Analyze viral patterns, generate scripts, and let 100 AI personas vote
      on the best content.
    </p>

    <div class="flex gap-4">
      <a
        href="/create"
        class="rounded-lg bg-[var(--color-accent)] px-6 py-3 font-medium text-white transition-colors hover:bg-[var(--color-accent-hover)]"
      >
        Create Campaign
      </a>
      <a
        href="/runs"
        class="rounded-lg border border-[var(--color-border)] px-6 py-3 font-medium text-[var(--color-text-muted)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-text)]"
      >
        View Runs
      </a>
    </div>

    <div class="mt-12 grid max-w-2xl grid-cols-3 gap-8 text-left">
      <div>
        <h3 class="mb-2 font-semibold text-[var(--color-accent)]">Discover</h3>
        <p class="text-sm text-[var(--color-text-muted)]">
          Analyze 100 viral videos to extract structural patterns that drive engagement.
        </p>
      </div>
      <div>
        <h3 class="mb-2 font-semibold text-[var(--color-accent)]">Generate</h3>
        <p class="text-sm text-[var(--color-text-muted)]">
          Create 50 candidate scripts using proven patterns, personalized to your voice.
        </p>
      </div>
      <div>
        <h3 class="mb-2 font-semibold text-[var(--color-accent)]">Evaluate</h3>
        <p class="text-sm text-[var(--color-text-muted)]">
          100 AI personas vote on the best scripts. Watch the election unfold live.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

---
interface Props {
  title?: string;
}

const { title = "Flair — AI Script Studio" } = Astro.props;

const navLinks = [
  { href: "/create", label: "Create" },
  { href: "/runs", label: "Runs" },
  { href: "/insights", label: "Insights" },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- Corner labels (V1 branding) -->
    <div class="fixed top-5 left-7 z-50 text-[10px] uppercase tracking-[0.24em] opacity-50 font-ui">
      Flair
    </div>
    <div class="fixed top-5 right-7 z-50 text-[10px] uppercase tracking-[0.24em] opacity-50 font-ui flex items-center gap-2">
      <span class="h-1.5 w-1.5 rounded-full bg-[var(--stud-a)] animate-pulse"></span>
      AI Script Studio
    </div>
    <div class="fixed bottom-5 right-7 z-50 text-[10px] uppercase tracking-[0.24em] opacity-50 font-ui">
      2026
    </div>

    <!-- Background watermarks -->
    <div class="watermark text-[clamp(68px,12.5vw,164px)] top-[10%] left-[-2%] rotate-[-8deg]">FLAIR</div>
    <div class="watermark text-[clamp(48px,8vw,100px)] bottom-[15%] right-[5%] rotate-[4deg] opacity-[0.03]">STUDIO</div>

    <!-- Navigation -->
    <nav class="relative z-40 border-b border-[var(--color-border)]">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href="/" class="font-display text-xl tracking-[0.12em] text-[var(--color-ink)]">
          Flair<span class="text-[var(--stud-a)]">2</span>
        </a>
        <div class="flex gap-8">
          {
            navLinks.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  "font-ui text-[11px] uppercase tracking-[0.14em] transition-all duration-200",
                  currentPath === href || currentPath.startsWith(href + "/")
                    ? "text-[var(--color-ink)] font-medium"
                    : "text-[var(--color-text-muted)] hover:text-[var(--color-ink)]",
                ]}
              >
                {label}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    <main class="relative z-10 mx-auto max-w-5xl px-6 py-8">
      <slot />
    </main>

    <!-- Legend (right sidebar) -->
    <div class="fixed right-7 top-1/2 -translate-y-1/2 z-40 hidden lg:flex flex-col gap-4">
      <div class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--disc-a)]"></span>
        <span class="text-[10px] uppercase tracking-[0.14em] opacity-50 font-ui">Discover</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--stud-a)]"></span>
        <span class="text-[10px] uppercase tracking-[0.14em] opacity-50 font-ui">Generate</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--eval-a)]"></span>
        <span class="text-[10px] uppercase tracking-[0.14em] opacity-50 font-ui">Evaluate</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--pers-a)]"></span>
        <span class="text-[10px] uppercase tracking-[0.14em] opacity-50 font-ui">Personalize</span>
      </div>
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

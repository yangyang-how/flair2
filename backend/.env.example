# Flair2 Backend — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# LLM API Keys (at least one required for pipeline)
FLAIR2_GEMINI_API_KEY=
FLAIR2_KIMI_API_KEY=
FLAIR2_OPENAI_API_KEY=

# Pipeline defaults (optional — these are the defaults)
# FLAIR2_S1_VIDEO_COUNT=100
# FLAIR2_S3_SCRIPT_COUNT=50
# FLAIR2_S4_PERSONA_COUNT=100
# FLAIR2_S6_TOP_N=10

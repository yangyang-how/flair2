# Flair2 AI Campaign Studio — Environment Variables
# Copy to .env and fill in your values

# LLM API Keys
FLAIR2_GEMINI_API_KEY=your-gemini-key-here
FLAIR2_KIMI_API_KEY=sk-kimi-your-key-here
FLAIR2_OPENAI_API_KEY=your-openai-key-here

# Pipeline Defaults (optional — these have sensible defaults)
# FLAIR2_S1_VIDEO_COUNT=100
# FLAIR2_S3_SCRIPT_COUNT=50
# FLAIR2_S4_PERSONA_COUNT=100
# FLAIR2_S6_TOP_N=10

# App Settings (optional)
# FLAIR2_DEBUG=false
# FLAIR2_ENVIRONMENT=dev
